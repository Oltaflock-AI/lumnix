# ─── App ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ─── Supabase (required) ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Token signing (required in prod) ────────────────────────────────
# 32+ random bytes. Used by OAuth state + email unsubscribe tokens.
# Generate: openssl rand -base64 48
OAUTH_STATE_SECRET=

# ─── Cron auth (required) ────────────────────────────────────────────
# Bearer token Vercel cron sends; timing-safe compared in route handlers.
CRON_SECRET=

# ─── AI ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Email (Resend) ──────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@yourdomain.com
EMAIL_FROM=no-reply@yourdomain.com
EMAIL_FROM_NAME=Lumnix

# ─── Google OAuth (GSC + GA4 + Google Ads) ───────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=

# ─── Meta Ads (one of: user token OR app id+secret) ──────────────────
META_ACCESS_TOKEN=
META_APP_ID=
META_APP_SECRET=

# ─── Billing (Stripe) ────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_GROWTH=price_xxx
STRIPE_PRICE_AGENCY=price_xxx
